# ═══════════════════════════════════════════
# FinTrack AI — Environment Configuration
# ═══════════════════════════════════════════

# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Server ───────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT Secret (REQUIRED) ────────────────
# Generate a strong random key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-this

# ─── Turso Database (REQUIRED for production/Vercel) ──
# Create a free database at https://turso.tech
TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Email / OTP (optional — OTP codes still print to server logs in dev) ──
APP_NAME=FinTrack AI

# Option A: Full SMTP connection URL
SMTP_URL=smtp://user:pass@smtp.example.com:587

# Option B: Individual SMTP fields (used if SMTP_URL is empty)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=false

# Sender address for OTP emails
SMTP_FROM="FinTrack AI <noreply@yourdomain.com>"
SMTP_DOMAIN=yourdomain.com
